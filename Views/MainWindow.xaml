<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TaskApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TaskApp.Models"
    mc:Ignorable="d"
    Title="TaskApp">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid ColumnDefinitions="*,*" Padding="30">

        <!-- LEFT PANEL -->
        <StackPanel Spacing="15">

            <!-- Header -->
            <TextBlock Text="📝 My Tasks"
                       FontSize="28"
                       FontWeight="Bold" />

            <!-- Input Box -->
            <TextBox Text="{x:Bind TaskViewModel.NewTask.Title, Mode=TwoWay}"
                     PlaceholderText="Enter a new task..."
                     Padding="10"
                     CornerRadius="8"/>

            <!-- Add Button -->
            <Button Content="Add Task"
                    Command="{x:Bind TaskViewModel.AddTaskCommand}"
                    HorizontalAlignment="Stretch"
                    Background="#4CAF50"
                    Foreground="White"
                    CornerRadius="8"/>

        </StackPanel>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="15"
                Margin="20,0,0,0">

            <StackPanel Spacing="10">

                <TextBlock Text="📌 Task List"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                <ListView ItemsSource="{x:Bind TaskViewModel.TaskList}">

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TaskItem">

                            <Border Background="#2A2A2A"
                                    Padding="10"
                                    CornerRadius="8"
                                    Margin="0,5">

                                <StackPanel Orientation="Horizontal"
                                            Spacing="10">

                                    <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" />

                                    <TextBlock Text="{x:Bind Title}"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>

                                    <!-- Delete Button (future feature) -->
                                    <Button Content="❌"
                                            Background="Transparent"
                                            Foreground="Red"
                                            BorderThickness="0"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

            </StackPanel>

        </Border>

    </Grid>
</Window>