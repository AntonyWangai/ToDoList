<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TaskApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TaskApp.Models"
    x:Name="Window"
    Title="TaskApp"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="30" ColumnDefinitions="*,*">

        <!--  LEFT PANEL  -->
        <StackPanel Spacing="15">

            <!--  Header  -->
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="📝 My Tasks" />

            <!--  Input Box  -->
            <TextBox
                Padding="10"
                CornerRadius="8"
                PlaceholderText="Enter a new task..."
                Text="{x:Bind TaskViewModel.NewTask.Title, Mode=TwoWay}" />

            <!--  Add Button  -->
            <Button
                HorizontalAlignment="Stretch"
                Background="#4CAF50"
                Command="{x:Bind TaskViewModel.AddTaskCommand}"
                Content="Add Task"
                CornerRadius="8"
                Foreground="White" />

        </StackPanel>

        <!--  RIGHT PANEL  -->
        <Border
            Grid.Column="1"
            Margin="20,0,0,0"
            Padding="15"
            Background="#1E1E1E"
            CornerRadius="12">

            <StackPanel Spacing="10">

                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="📌 Task List" />

                <TextBlock
                    FontSize="18"
                    Foreground="White"
                    Text="Today" />
                <ListView ItemsSource="{x:Bind TaskViewModel.TaskList}">


                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TaskItem">

                            <Border
                                Margin="0,5"
                                Padding="10"
                                Background="#2A2A2A"
                                CornerRadius="8">

                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">

                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="White"
                                        Text="{x:Bind Title}" />

                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="Gray"
                                        Text="{x:Bind DateAdded, Mode=OneWay}" />

                                    <!--  Delete Button  -->
                                    <Button
                                        Grid.Column="3"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding Path=TaskViewModel.DeleteTaskCommand, ElementName=Window}"
                                        CommandParameter="{x:Bind}"
                                        Content="❌"
                                        Foreground="Red" />

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

            </StackPanel>

        </Border>

    </Grid>
</Window>